    "@pnftrading/codei-adapter-php": "workspace:*",
    "@pnftrading/codei-adapter-rust": "workspace:*",
    "@pnftrading/codei-adapter-csharp": "workspace:*",
    "@pnftrading/codei-adapter-cpp": "workspace:*",
    "@pnftrading/codei-adapter-swift": "workspace:*",
    "@pnftrading/codei-core": "workspace:*",
    "commander": "^12.0.0",
